   "source": [
    "import numpy as np\n",
    "rng = np.random.default_rng(108)\n",
    "\n",
    "\n",
    "def roll_dice(n):\n",
    "    return rng.integers(1, n+1)\n",
    "\n",
    "\n",
    "pnl = 0\n",
    "for i in range(10**5):\n",
    "    philip = roll_dice(30)\n",
    "    brendon = roll_dice(20)\n",
    "    payoff = philip if philip > brendon else - brendon\n",
    "    pnl += payoff / 10**5\n",
    "\n",
    "\n",
    "print(pnl)"
   ]
  },
